generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  // Notice we removed the url line here for Prisma 7 compatibility!
}

model Student {
  id        Int      @id @default(autoincrement())
  studentId String   @unique
  fullName  String
  className String   
  section   String
  mobile    String
  faceData  String   @db.Text 
  createdAt DateTime @default(now())
}

model Attendance {
  id        Int      @id @default(autoincrement())
  studentId String
  name      String
  date      String
  time      String
  status    String   @default("Present")
  createdAt DateTime @default(now())
}